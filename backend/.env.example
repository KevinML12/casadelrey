# ─────────────────────────────────────────────────────────────────────────────
# CasaDelRey Backend — Variables de Entorno
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como `.env` para desarrollo local:
#   cp .env.example .env
#
# En Dokploy (producción): pegar cada variable en
#   Service → Environment Variables → Add Variable
# ─────────────────────────────────────────────────────────────────────────────


# ── Base de Datos (REQUERIDA) ─────────────────────────────────────────────────
# Usar el Session Mode Pooler de Supabase (puerto 5432).
# Supabase Dashboard → Settings → Database → Connection string → Session mode
#
# IMPORTANTE: NO usar el Transaction mode (puerto 6543) — GORM usa prepared
# statements y no es compatible con ese modo de pgBouncer.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres


# ── Autenticación JWT (REQUERIDA) ─────────────────────────────────────────────
# Clave secreta para firmar y validar los tokens JWT.
# Generar en Linux/Mac con: openssl rand -hex 32
# Generar en Windows con:   [System.Web.Security.Membership]::GeneratePassword(64, 10)
# Debe ser aleatoria, mínimo 32 caracteres, y NUNCA compartirse.
JWT_SECRET=REEMPLAZAR_CON_CLAVE_ALEATORIA_DE_64_CHARS


# ── Entorno ───────────────────────────────────────────────────────────────────
# "production" en Dokploy (omite la carga del archivo .env local)
# "development" en local (activa godotenv para leer este archivo)
ENV=development


# ── Puerto del Servidor ───────────────────────────────────────────────────────
# Dokploy mapea este puerto al exterior. Coincidir con el EXPOSE del Dockerfile.
PORT=8080


# ── CORS — URL del Frontend (RECOMENDADA) ─────────────────────────────────────
# URL exacta del frontend en Vercel. Se agrega a la lista de orígenes permitidos.
# Ejemplo: https://casadelreyhue.vercel.app
# Sin barra final.
CLIENT_URL=https://casadelreyhue.vercel.app


# ── SendGrid — Emails Transaccionales (OPCIONAL) ──────────────────────────────
# Para enviar emails de bienvenida y reseteo de contraseña.
# SendGrid Dashboard → Settings → API Keys → Create API Key (Restricted: Mail Send)
SENDGRID_API_KEY=SG.REEMPLAZAR_CON_TU_CLAVE_DE_SENDGRID


# ── Cloudflare R2 — Storage de archivos (fotos, comprobantes, galería) ────────
#
# El sistema detecta automáticamente si usar R2 o almacenamiento local:
#   - Si TODAS las vars CF_R2_* están presentes → usa R2
#   - Si falta alguna → fallback a ./uploads local (perfecto para dev)
#
# Para DEV (tu cuenta):
#   Cloudflare Dashboard → R2 → API Tokens → Create Token
#   Permisos: Object Read & Write sobre el bucket específico
#
# Para PROD (cuenta del cliente):
#   Mismos pasos en la cuenta de ellos → setear en Fly.io secrets
#   fly secrets set CF_R2_ACCOUNT_ID=xxx CF_R2_ACCESS_KEY=xxx ...
#
# ──────────────────────────────────────────────────────────────────────────────

# ID de la cuenta Cloudflare (Dashboard → lado derecho, "Account ID")
CF_R2_ACCOUNT_ID=

# Token de API R2 (Access Key y Secret generados en R2 → Manage R2 API Tokens)
CF_R2_ACCESS_KEY=
CF_R2_SECRET_KEY=

# Nombre del bucket (crearlo en Cloudflare R2 → Create bucket)
# Sugerencia dev (tuya):    casadelreyhue-dev
# Sugerencia prod (cliente): casadelreyhue-media
CF_R2_BUCKET=casadelreyhue-dev

# URL pública del bucket para servir los archivos
# Opción A — dominio personalizado (recomendado para prod):
#   Cloudflare R2 → bucket → Settings → Custom Domains → Connect Domain
#   CF_R2_PUBLIC_URL=https://cdn.casadelreyhue.org
# Opción B — URL pública de R2 (para dev o pruebas rápidas):
#   Cloudflare R2 → bucket → Settings → Public Access → Allow Access → copia la URL
#   CF_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev
CF_R2_PUBLIC_URL=https://pub-REEMPLAZAR.r2.dev

# URL base del servidor (para URLs locales cuando R2 no está configurado)
BASE_URL=http://localhost:8080


# ── ElevenLabs — Voz IA para leer posts del blog (OPCIONAL) ───────────────────
# Si está configurada, los posts se leen con voz IA natural en español.
# elevenlabs.io → Profile → API Key. Free tier: 10k chars/mes.
# Sin esta variable se usa Google Translate (gratis, calidad aceptable).
ELEVENLABS_API_KEY=


# ── Supabase — Auth Externo (OPCIONAL) ────────────────────────────────────────
# Solo necesario si se usa Supabase como proveedor de autenticación externo.
# El sistema actual usa autenticación propia (JWT generado por el backend).
SUPABASE_URL=https://fnpymdtvhnzgwivihjks.supabase.co
SUPABASE_KEY=REEMPLAZAR_CON_SERVICE_ROLE_KEY_DE_SUPABASE
