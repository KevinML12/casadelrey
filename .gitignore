# ══════════════════════════════════════════════════════════════════
#  ⚠️ ESTE REPO ES PÚBLICO — todo lo sensible debe estar aquí.
#  Regla: credenciales, datos personales y binarios NUNCA se commitean.
# ══════════════════════════════════════════════════════════════════

# ── Secretos y credenciales ─────────────────────────────────────────
.env
.env.local
.env.*.local
**/.env
*.local.md
*.local.txt
docs/CREDENCIALES*
backend/scripts/rotate_creds/
backend/scripts/users_seed.csv
*.pem
*.key
*credentials*.json

# ── Datos privados del cliente (direcciones, teléfonos de líderes) ──
docs/CONTEXTO_IGLESIA.md

# ── Dependencias ────────────────────────────────────────────────────
node_modules/
**/node_modules/
vendor/

# ── Builds y binarios ───────────────────────────────────────────────
dist/
build/
**/dist/
**/build/
*.exe
tmp_*
backend/main
backend/uploads/

# ── IDE / OS ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs y coverage ─────────────────────────────────────────────────
*.log
npm-debug.log*
coverage/
*.out

# ── Playwright E2E: reportes/trazas (se regeneran en cada corrida) ──
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/

# ── Media y muestras locales (fotos originales sin optimizar) ───────
# Regla: las fotos crudas NUNCA van al repo. Solo se commitean las
# optimizadas en frontend/public/images/ (las que usa el sitio).
frontend/DOMINGOS\ 2026/
frontend/WILD\ YOUTH\ FOTOGRAFR*
frontend/liquid\ glass/
apple_sample/
frontend/ComposingCustomLayoutsWithSwiftUI/
# Zona segura: suelta aquí cualquier foto nueva (WhatsApp, cámara, etc.)
frontend/fotos-crudas/
# Red de seguridad: imágenes y videos sueltos en la raíz de frontend/
frontend/*.jpg
frontend/*.jpeg
frontend/*.png
frontend/*.heic
frontend/*.mp4
frontend/*.mov
frontend/*.zip

# ── Config local de Claude Code ─────────────────────────────────────
.claude/settings.local.json
